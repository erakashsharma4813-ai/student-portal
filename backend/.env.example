# Database
DATABASE_URL=postgresql://username:password@localhost:5432/student_portal

# Security
SECRET_KEY=your-super-secret-key-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin User (First Super User)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# OTP Configuration
ENABLE_OTP_VERIFICATION=false  # Set to true to require phone OTP verification during signup
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# SMS Provider (MSG91 - Configure when ready to use)
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_SENDER_ID=STUAPP  # 6-character alphanumeric sender ID
# MSG91_TEMPLATE_ID=your-approved-template-id
# MSG91_ROUTE=4  # 4 for transactional/OTP messages

# Note: Payment is handled manually - admin approves orders after receiving payment offline
